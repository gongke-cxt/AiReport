{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aireport.local/schemas/report-dashboard-dsl.v1.json",
  "title": "AiReport Document DSL",
  "type": "object",
  "required": ["version", "type", "pages", "datasets"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "type": {
      "type": "string",
      "enum": ["report", "dashboard"]
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "maxLength": 2000
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "mode": { "type": "string", "enum": ["light", "dark"] },
        "tokens": {
          "type": "object",
          "additionalProperties": { "type": ["string", "number"] }
        }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/page" }
    },
    "datasets": {
      "type": "array",
      "items": { "$ref": "#/$defs/dataset" }
    },
    "parameters": {
      "type": "array",
      "description": "报表级参数（日期范围、下拉等），供查询绑定引用",
      "items": { "$ref": "#/$defs/parameter" }
    }
  },
  "$defs": {
    "page": {
      "type": "object",
      "required": ["id", "widgets"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-zA-Z0-9_-]+$" },
        "title": { "type": "string" },
        "layout": { "$ref": "#/$defs/layout" },
        "widgets": {
          "type": "array",
          "items": { "$ref": "#/$defs/widget" }
        }
      }
    },
    "layout": {
      "type": "object",
      "required": ["engine"],
      "additionalProperties": true,
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["flow", "grid", "free"]
        },
        "columns": {
          "type": "integer",
          "minimum": 4,
          "maximum": 48,
          "default": 24
        },
        "rowHeight": {
          "type": "integer",
          "minimum": 4,
          "maximum": 200,
          "default": 8
        },
        "canvas": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "width": { "type": "integer", "minimum": 800, "default": 1920 },
            "height": { "type": "integer", "minimum": 600, "default": 1080 }
          }
        }
      }
    },
    "widget": {
      "type": "object",
      "required": ["id", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-zA-Z0-9_-]+$" },
        "kind": {
          "type": "string",
          "description": "组件类型，如 chart.line / kpi / table / filter.date",
          "pattern": "^[a-z0-9_.-]+$"
        },
        "title": { "type": "string" },
        "rect": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "w": { "type": "number", "minimum": 1 },
            "h": { "type": "number", "minimum": 1 },
            "z": { "type": "integer" }
          }
        },
        "binding": { "$ref": "#/$defs/binding" },
        "style": {
          "type": "object",
          "additionalProperties": true
        },
        "interaction": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "drill": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "link": {
              "type": "object",
              "properties": {
                "url": { "type": "string" }
              },
              "additionalProperties": true
            }
          }
        },
        "refresh": { "$ref": "#/$defs/refreshPolicy" }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "datasetId": { "type": "string" },
        "x": { "type": "string" },
        "y": {
          "type": "array",
          "items": { "type": "string" }
        },
        "series": { "type": "string" },
        "value": { "type": "string" },
        "label": { "type": "string" },
        "columns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field"],
            "properties": {
              "field": { "type": "string" },
              "header": { "type": "string" },
              "format": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "filters": {
          "type": "array",
          "items": { "$ref": "#/$defs/filterClause" }
        },
        "sort": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field"],
            "properties": {
              "field": { "type": "string" },
              "order": { "type": "string", "enum": ["asc", "desc"] }
            },
            "additionalProperties": false
          }
        },
        "limit": { "type": "integer", "minimum": 1, "maximum": 100000 }
      }
    },
    "filterClause": {
      "type": "object",
      "required": ["field", "op"],
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string" },
        "op": {
          "type": "string",
          "enum": ["eq", "neq", "gt", "gte", "lt", "lte", "in", "between", "like"]
        },
        "value": {},
        "paramRef": {
          "type": "string",
          "description": "引用 parameters 中的参数 id"
        }
      }
    },
    "refreshPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["manual", "interval", "realtime"]
        },
        "seconds": {
          "type": "integer",
          "minimum": 5,
          "maximum": 86400
        }
      }
    },
    "dataset": {
      "type": "object",
      "required": ["id", "sourceRef"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-zA-Z0-9_-]+$" },
        "name": { "type": "string" },
        "sourceRef": { "$ref": "#/$defs/sourceRef" },
        "cachePolicy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ttlSeconds": { "type": "integer", "minimum": 0, "maximum": 86400 }
          }
        }
      }
    },
    "sourceRef": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "connectionId", "sql"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "sql" },
            "connectionId": { "type": "string" },
            "sql": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "required": ["type", "connectionId", "table"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "table" },
            "connectionId": { "type": "string" },
            "schema": { "type": "string" },
            "table": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "required": ["type", "url"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "http" },
            "url": { "type": "string", "format": "uri" },
            "method": { "type": "string", "enum": ["GET", "POST"], "default": "GET" }
          }
        }
      ]
    },
    "parameter": {
      "type": "object",
      "required": ["id", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-zA-Z0-9_-]+$" },
        "label": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["dateRange", "date", "string", "number", "enum"]
        },
        "default": {}
      }
    }
  }
}
